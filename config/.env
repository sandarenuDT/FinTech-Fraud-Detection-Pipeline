# ─── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=transactions

# ─── PostgreSQL ───────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=fraud_db
PG_USER=fraud_user
PG_PASS=fraud_pass
PG_URL=jdbc:postgresql://localhost:5432/fraud_db

# ─── Spark ────────────────────────────────────────────────────
SPARK_MASTER=spark://localhost:7077

# ─── Fraud Rules ──────────────────────────────────────────────
HIGH_VALUE_THRESHOLD=5000
TRAVEL_WINDOW_MINUTES=10
